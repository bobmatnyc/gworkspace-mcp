# Google Workspace MCP Publishing Environment Configuration
# Copy to .env.local and fill in your API tokens

# PyPI API Token (for publishing to PyPI)
# Get from https://pypi.org/manage/account/token/
PYPI_TOKEN=pypi-your-token-here

# GitHub Personal Access Token (for releases and homebrew tap)
# Needs: repo, workflow, write:packages scopes
# Get from https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-token-here

# Homebrew Tap Token (usually same as GITHUB_TOKEN)
# For updating the shared bobmatnyc/homebrew-tools tap
HOMEBREW_TAP_TOKEN=gho_your-token-here

# Optional: Custom GitHub repository settings
GITHUB_OWNER=bobmatnyc
GITHUB_REPO=gworkspace-mcp

# Optional: Custom homebrew tap repository
# Default: Uses shared bobmatnyc/homebrew-tools tap (recommended)
HOMEBREW_TAP_REPO=https://github.com/bobmatnyc/homebrew-tools.git

# Note: Store .env.local in a secure location and never commit to git
# .env.local is already in .gitignore for safety
